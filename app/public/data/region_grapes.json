{
  "_metadata": {
    "purpose": "Curated grape associations for the 59 Vinotheca regions, used by Grape Resonances to map matched regions to grape recommendations.",
    "curation_rules": {
      "tier_definitions": {
        "signature": "What the region is famous for; the grape any wine-curious reader already associates with the place.",
        "lesser_known": "Recognized by occasional readers but not the obvious answer. Tier from which temperament_seconds is drawn.",
        "rare": "Even moderately serious enthusiasts haven't heard of these. Up to 4 entries when deeper cuts exist; may be empty for regions without rare answers.",
        "temperament_seconds": "The lesser-known grape from this region that most embodies the region's identity. Always a subset of lesser_known. Used by the cluster-level aggregator. Curatorial principle: tiers are region-relative (what the region keeps), not market-relative (what the global market notices)."
      },
      "parentheticals": "Allowed for disambiguation when a grape name alone is ambiguous (e.g. 'Gamay (Hautes-Côtes)').",
      "asymmetry": "Some regions (Walla Walla, parts of New Zealand) lack natural Tier 2 candidates because they grow mostly international varieties. Such regions get an empty temperament_seconds; the aggregator does not force a Tier 2 grape per region."
    },
    "schema_version": "v1",
    "started": "2026-05-10",
    "n_regions_total": 59,
    "curation_order": "cluster-by-cluster, starting with Old World Interior",
    "n_regions_curated": 59,
    "completion_date": "2026-05-10"
  },
